# Customer integration keys

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Google Gemini Image Generation
GEMINI_API_KEY=AIza...
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Google Sheets
GOOGLE_SHEETS_SPREADSHEET_ID=1Abc...
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./config/google-service-account.json
GOOGLE_SHEETS_TAB_NAME=Sheet1

# App server
PORT=3000

# Multi-brand routing
ACTIVE_BRAND=default

# Instagram publishing
INSTAGRAM_ACCESS_TOKEN=ig-user-access-token
INSTAGRAM_APP_SCOPED_USER_ID=1784...
INSTAGRAM_GRAPH_BASE_URL=https://graph.instagram.com
INSTAGRAM_GRAPH_API_VERSION=v25.0
PUBLIC_BASE_URL=https://your-public-url
INSTAGRAM_AUTO_PUBLISH=false

# Queue worker
AUTO_QUEUE_ENABLED=false
AUTO_QUEUE_INTERVAL_MS=300000
