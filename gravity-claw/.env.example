# GravityClaw environment variables (copy to .env and fill with your secrets)
PROJECT_NAME=GravityClaw
OWNER_NAME=Jack Roberts
PRIMARY_CHANNEL=telegram

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=

# LLM provider (OpenRouter, OpenAI, etc.)
OPEN_ROUTER_KEY=
OPEN_ROUTER_BASE_URL=https://api.openrouter.ai/v1

# Vector memory (Pinecone or compatible)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=gravity-claw-memory

# TTS / voice output
ELEVEN_LABS_API_KEY=
ELEVEN_LABS_VOICE=alloy

# Speech-to-text (Gro, OpenAI Whisper, etc.)
GRO_API_KEY=
GRO_PROJECT_ID=
WHISPER_MODEL=gpt-4o-mini-transcribe

# Remote hosting (Railway)
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_SERVICE_NAME=gravity-claw

# Optional connectors
ZAPPY_API_KEY=
SUPABASE_SERVICE_URL=
SUPABASE_ANON_KEY=
